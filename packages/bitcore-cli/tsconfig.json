{
  "compilerOptions": {
    "lib": [
      "ES2020",
      "ES2022",
      "DOM"
    ],
    "noImplicitAny": false,
    "removeComments": true,
    "declaration": true,
    "declarationMap": true,
    "module": "nodenext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "target": "ES2020",
    "outDir": "build",
    "sourceMap": true,
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "./src/**/*.ts",
    "./test/**/*.ts",
    "./types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}